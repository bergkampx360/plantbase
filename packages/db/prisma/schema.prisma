datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// docs/stack.md — kategorikus mezők értékkészletei:
// category:   szobanövény / kerti / pozsgás / kaktusz / fűszer / fa-cserje / lógó / virágzó
// location:   beltéri / kültéri / mindkettő
// light:      árnyék / alacsony / közepes / erős / direkt nap
// watering:   ritka / közepes / gyakori / állandóan nedves
// difficulty: kezdő / haladó / profi
model Product {
  id                Int      @id @default(autoincrement())
  name              String
  latin_name        String   @unique
  category          String
  location          String
  price             Decimal
  sale_price        Decimal?
  stock             Int
  light             String
  watering          String
  difficulty        String
  current_height_cm Int
  max_height_cm     Int
  current_pot_cm    Int
  pet_safe          Boolean
  kid_safe          Boolean
  air_purifying     Boolean
  rating            Decimal
  reviews_count     Int
  description       String

  @@map("products")
}
