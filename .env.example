# Alkalmazás futásidejű változók (CLAUDE.md: "Application runtime variables belong in .env").
# Másold .env néven, töltsd ki, és soha ne commitold (lásd .gitignore).

# Prisma (read-write): séma, migráció, seed. Lásd docker-compose.yml (POSTGRES_USER/POSTGRES_DB: plantbase).
DATABASE_URL=postgresql://plantbase:<password>@localhost:5433/plantbase

# Az agent runSql tooljának kapcsolata — kizárólag a read-only plantbase_ro szerepkörön
# keresztül (docs/architektura.md, 2. döntés; docker/postgres/initdb hozza létre).
DATABASE_URL_READONLY=postgresql://plantbase_ro:<password>@localhost:5433/plantbase

# Anthropic API — az askAgent (packages/core) LLM-hívásaihoz.
ANTHROPIC_API_KEY=
# Alapértelmezett: claude-haiku-4-5 — az OpenAI gpt-4o-mini-hez hasonló kategóriájú,
# gyors/olcsó Anthropic modell (ld. docs/implementation-plan.md "Rögzített technikai
# döntések"). Felülírható, pl. claude-sonnet-5-re, ha minőségi okból szükség lenne rá.
ANTHROPIC_MODEL=claude-haiku-4-5
